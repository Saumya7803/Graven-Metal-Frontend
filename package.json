{
  "name": "graven-metal-monorepo",
  "private": true,
  "workspaces": [
    "frontend",
    "admin-panel",
    "backend"
  ],
  "scripts": {
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:admin": "npm --prefix admin-panel run dev",
    "dev:backend": "npm --prefix backend run dev",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:admin\" \"npm run dev:backend\"",
    "build": "npm --prefix frontend run build && npm --prefix admin-panel run build",
    "start:backend": "npm --prefix backend run start"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
